---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Bio"
  description="Background and career history of Apoorv Shah — lawyer, teacher, and education leader."
  activeNav="bio"
>
  <div class="container">

    <div class="page-header">
      <h1>Bio</h1>
    </div>

    <section class="bio-section">
      <h2>Career</h2>
      <ul class="bio-timeline">
        <li>
          <span class="bio-year">2008 – 2013</span>
          <span class="bio-role">Studied law at Gujarat National Law University</span>
        </li>
        <li>
          <span class="bio-year">2013 – 2015</span>
          <span class="bio-role">Taught 7th and 8th grade English and Civics through the Teach For India Fellowship</span>
        </li>
        <li>
          <span class="bio-year">2015 – 2018</span>
          <span class="bio-role">Program Manager at Teach For India — managed, trained, and coached a team of ~17 fellows each year</span>
        </li>
        <li>
          <span class="bio-year">2018 – 2019</span>
          <span class="bio-role">Coached 10 School Empowerment Managers at 321 Education Foundation</span>
        </li>
        <li>
          <span class="bio-year">2019 – 2024</span>
          <span class="bio-role">Led City Operations for Ahmedabad at Teach For India</span>
        </li>
        <li>
          <span class="bio-year">2026 – present</span>
          <span class="bio-role">Lead Strategy and Marketing at Riverside Learning Center</span>
        </li>
      </ul>
    </section>

    <section class="bio-section">
      <h2>Organisations worth supporting</h2>
      <ul class="bio-orgs">
        <li>
          <a href="https://www.teachforindia.org" target="_blank" rel="noopener noreferrer">Teach For India</a>
        </li>
        <li>
          <a href="https://www.designforchange.us" target="_blank" rel="noopener noreferrer">Design For Change</a>
        </li>
        <li>
          <a href="https://www.xkdr.org" target="_blank" rel="noopener noreferrer">XKDR Forum</a>
        </li>
        <li>
          Ummed Community Learning Center, Pune
        </li>
      </ul>
    </section>

  </div>
</BaseLayout>
