---
import BaseLayout from './BaseLayout.astro';

interface Props {
  title: string;
  date: Date;
  description: string;
}

const { title, date, description } = Astro.props;

const formattedDate = date.toLocaleDateString('en-IN', {
  day: 'numeric',
  month: 'long',
  year: 'numeric',
});
---

<BaseLayout title={title} description={description} activeNav="writing">
  <div class="container">
    <article>
      <header class="post-header">
        <h1>{title}</h1>
        <time class="post-date" datetime={date.toISOString()}>{formattedDate}</time>
      </header>

      <div class="post-content">
        <slot />
      </div>

      <a href="/writing" class="back-link">← Back to Writing</a>
    </article>
  </div>
</BaseLayout>
